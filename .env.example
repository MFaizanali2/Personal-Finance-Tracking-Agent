# Finance Tracker Agent Configuration

# Server
HOST=0.0.0.0
PORT=8000

# MongoDB (local or Atlas)
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=finance_tracker

# Logging
LOG_LEVEL=INFO

# Agent
MAX_CYCLES=10
FLAG_THRESHOLD=5000
